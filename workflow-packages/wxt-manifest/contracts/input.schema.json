{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wxt-manifest input",
  "type": "object",
  "required": ["request_id", "task", "bounded_context"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "task": { "type": "string", "minLength": 1 },
    "target_domain": { "type": ["string", "null"], "const": "wxt" },
    "bounded_context": {
      "type": "object",
      "required": ["selected_files", "config_fragments"],
      "properties": {
        "selected_files": { "type": "array", "items": { "type": "string" } },
        "config_fragments": { "type": "array", "items": { "type": "string" } },
        "host_hints": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
