{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wxt-manifest output",
  "type": "object",
  "required": ["request_id", "status", "main_pack", "artifacts", "validation_results", "summary"],
  "properties": {
    "request_id": { "type": "string" },
    "status": { "type": "string", "enum": ["completed", "partial", "handoff", "failed"] },
    "main_pack": { "type": ["string", "null"] },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "kind"],
        "properties": {
          "name": { "type": "string" },
          "kind": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "validation_results": { "type": "array" },
    "handoff": { "type": ["object", "null"] },
    "summary": { "type": "string" }
  },
  "additionalProperties": true
}
